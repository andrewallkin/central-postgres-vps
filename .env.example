# postgres-central/.env.example
# Copy to .env and fill in values

# Superuser / admin account
POSTGRES_USER=pgadmin

# Use a proper random password: openssl rand -base64 24
POSTGRES_PASSWORD=your-strong-random-password

# Default DB (admin use only)
POSTGRES_DB=postgres

# Backup
GCP_SERVICE_ACCOUNT_CREDENTIALS=your-base64-encoded-service-account-json
GCS_DB_BACKUP_BUCKET_NAME=vps_postgres_backups
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE_HOUR=0,12
BACKUP_SCHEDULE_MINUTE=0
BACKUP_TIMEZONE=Africa/Johannesburg